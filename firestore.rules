// firestore.rules
// Paste this into Firebase Console → Firestore Database → Rules tab

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ─────────────────────────────────────────────────────────────
    // Each user can only read and write their own profile document.
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ── Wallets ───────────────────────────────────────────────────────────
    // Only the wallet owner can read or write their wallet.
    // Updates are restricted: only balance and updatedAt may change
    // (prevents a user from changing their ownerId or currency arbitrarily).
    match /wallets/{walletId} {
      allow read: if request.auth != null
                  && resource.data.ownerId == request.auth.uid;

      allow update: if request.auth != null
                    && resource.data.ownerId == request.auth.uid
                    && request.resource.data.ownerId == resource.data.ownerId
                    && request.resource.data.currency == resource.data.currency;

      // Creation happens server-side via Cloud Function or admin SDK in production.
      // For development, allow authenticated users to create their own wallet.
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;
    }

    // ── Transactions ──────────────────────────────────────────────────────
    // A user can read any transaction they were involved in (as sender or receiver).
    // Transactions are immutable once written — no updates or deletes allowed.
    match /transactions/{txId} {
      allow read: if request.auth != null
                  && (resource.data.senderId   == request.auth.uid
                   || resource.data.receiverId == request.auth.uid);

      allow create: if request.auth != null;

      // Immutable — never allow updates or deletes
      allow update, delete: if false;
    }

    // ── Username registry ─────────────────────────────────────────────────
    // Any signed-in user can check username availability (read).
    // Writes are handled inside a server-side transaction during sign-up.
    // In production, move writes to a Cloud Function; for dev allow create.
    match /usernames/{username} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
